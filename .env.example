########################################
# DataGrabber example configuration
# Copy this file to `.env` and edit.
########################################

# Flask / app settings
SECRET_KEY=change_me_to_any_random_string

# Maximum total upload size per request (200 MB per chunk; each folder batch is 10 files)
# MAX_CONTENT_LENGTH=209715200

# ── Performance tuning (advanced — defaults are fine for most setups) ──────────────
# Number of simultaneous AI API calls.  Must match your API tier's rate limit.
# Gemini free tier = 15 RPM → safe up to 5.  OpenAI Tier 1+ → safe up to 10.
# API_CONCURRENCY=5

# Number of rows to buffer in memory before writing to the Excel file.
# Higher = fewer disk writes (faster), lower = more frequent incremental saves.
# EXCEL_FLUSH_SIZE=10

# How many files to include in one internal processing batch (folder jobs).
# BATCH_SIZE=100

# Base URL (only used in some links; usually fine as default)
BASE_URL=http://localhost:8080

# ============================
# Database (local by default)
# ============================

# By default DataGrabber uses a local SQLite file:
#   ~/DataGrabber/datagrabber.db
# You normally do NOT need to set DATABASE_URL.

# If you know what you’re doing, you can point to Postgres instead:
# DATABASE_URL=postgresql://user:password@host:5432/datagrabber

# ============================
# AI provider configuration
# ============================

# Choose ONE main provider by setting AI_PROVIDER to:
#   gemini | openai | anthropic | openrouter | ollama

AI_PROVIDER=gemini
AI_MODEL=gemini-1.5-flash

## Gemini (default example)
GEMINI_API_KEY=your_gemini_key_here

## OpenAI (optional)
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=your_openai_key_here

## Anthropic (optional)
AI_PROVIDER=anthropic
AI_MODEL=claude-3-haiku-20240307
ANTHROPIC_API_KEY=your_anthropic_key_here

## OpenRouter (optional – many models via one key)
AI_PROVIDER=openrouter
AI_MODEL=openrouter/openai/gpt-4o-mini
OPENROUTER_API_KEY=your_openrouter_key_here

## Ollama (optional – local models)
# Make sure Ollama is installed and running, and you’ve pulled a model:
# ollama pull llama3.2
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# ============================
# Email (optional)
# ============================

# These are only needed if you want password reset
# emails and the contact form to send real mail.

# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=you@example.com
# SMTP_PASSWORD=your_app_password
# FROM_EMAIL=you@example.com


